{
  "name": "@incogdev/validate",
  "version": "3.0.0",
  "description": "Simple, fast, type-safe validation library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./rules": {
      "import": "./dist/rules.js",
      "types": "./dist/rules.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node test/test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "validation",
    "validator",
    "schema",
    "typescript",
    "email",
    "phone",
    "url"
  ],
  "author": "Incognito",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/incog-validate"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}