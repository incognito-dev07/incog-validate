{
  "name": "@incogdev/validate",
  "version": "2.1.1",
  "description": "Simple, fast, type-safe validation library",
  "main": "index.js",
  "types": "index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./rules": {
      "import": "./lib/rules.js",
      "types": "./index.d.ts"
    },
    "./schema": {
      "import": "./lib/schema.js",
      "types": "./index.d.ts"
    }
  },
  "keywords": [
    "validation",
    "validator",
    "schema",
    "typescript",
    "email",
    "phone",
    "url"
  ],
  "author": "Incognito",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/incog-validate"
  },
  "scripts": {
    "test": "node test/test.js",
    "test:ts": "tsc --noEmit test/test.ts"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
